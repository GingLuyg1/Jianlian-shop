# Jianlian Shop BEP20 phase 1 local test environment example.
# Copy values manually into .env.local only for local testing against Jianlian-shop-test.
# Do not paste production keys here. Do not commit real secrets.

# Supabase test project
NEXT_PUBLIC_SUPABASE_URL=https://<jianlian-shop-test-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<test-project-anon-key>

# Server-only Supabase admin key.
# Supports old service_role JWT or new sb_secret_... Secret API Key.
# Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=<test-project-service-role-or-sb-secret-key>

# USDT-BEP20 phase 1 fixed-address manual TxHash verification.
# For app-layer failure-path testing without real USDT, BSC_RPC_URL may point to
# a non-production test/mock RPC that returns safe failures. Real success testing
# requires a real BSC RPC and an actual BNB Smart Chain USDT transfer.
BSC_RPC_URL=https://<test-or-mock-bsc-rpc-url>
BSC_CHAIN_ID=56
BSC_USDT_CONTRACT=0x<test-usdt-bep20-contract-address>
BSC_USDT_DECIMALS=18
BSC_RECEIVE_ADDRESS=0x<dedicated-test-receive-address>
BSC_REQUIRED_CONFIRMATIONS=12
BSC_PAYMENT_EXPIRE_MINUTES=30
BSC_EXPLORER_BASE_URL=https://bscscan.com/tx

# Server-side CNY to USDT pricing snapshot.
USDT_PRICING_MODE=manual_fixed_rate
CNY_USDT_FIXED_RATE=<cny-per-usdt-fixed-rate>
CNY_USDT_RATE_TTL_SECONDS=300
USDT_AMOUNT_SCALE=6

# Optional general monitoring/readiness hooks. Leave blank for local testing.
MONITORING_WEBHOOK_URL=
ALERT_WEBHOOK_URL=
